{
  "config_general": {
    "description": "⚙️ 通用",
    "type": "object",
    "items": {
      "enabled": {
        "description": "启用插件",
        "type": "bool",
        "default": true,
        "hint": "此为必须项"
      },
      "enable_llm_tool": {
        "description": "注册为 AstrBot 函数工具",
        "type": "bool",
        "default": true,
        "hint": "此为必须项"
      },
      "enable_force_commands": {
        "description": "启用内部指令",
        "type": "bool",
        "default": true,
        "hint": "比如 /search 和 /搜索"
      },
      "enable_force_prefixes": {
        "description": "启用强制触发词",
        "type": "bool",
        "default": true,
        "hint": "关闭本选项可阻止插件被除内部指令以外的方式强制触发，使用本插件的时机完全由 [主 Bot] 判断"
      },
      "force_prefixes": {
        "description": "触发词列表",
        "type": "list",
        "default": ["搜索", "search"],
        "items": {
          "type": "string"
        }
      }
    }
  },
  "config_force_trigger": {
    "description": "🕹️ 强制触发",
    "type": "object",
    "items": {
      "force_trigger_mode": {
        "description": "处理模式",
        "type": "string",
        "default": "main_bot",
        "options": ["main_bot", "direct_reply"],
        "hint": "main_bot 模式：强制插入搜索结果内容到 [主 Bot] 的提示词 | direct_reply 模式：绕过 [主 Bot] 使用单独的 LLM 总结并回复"
      },
      "auto_search_policy": {
        "description": "搜索策略",
        "type": "string",
        "default": "tool",
        "options": ["tool", "always"],
        "hint": "always 会让普通消息也强制执行一次浏览器任务"
      },
      "max_urls_per_request": {
        "description": "单次最多处理的 URL 数",
        "type": "int",
        "default": 3
      }
    }
  },
  "config_main_bot": {
    "description": "✨ main_bot 模式",
    "type": "object",
    "items": {
      "forced_evidence_prompt_template": {
        "description": "主 Bot 提示词注入模板",
        "type": "text",
        "default": "用户明确要求使用 Obscura 浏览器能力。下面是 Obscura 得到的证据，请结合当前人格、上下文和用户原始问题回答。\n\n要求：\n1. 优先依据浏览器证据回答。\n2. 不要把证据之外的推测说成事实。\n3. 如证据不足或浏览失败，请按当前对话风格说明。\n4. 如果引用来源，可以使用 [1]、[2] 这样的编号。\n\n总结侧重点：{summary_focus}\n\n用户需求：\n{query}\n\n浏览器证据：\n{evidence}\n",
        "hint": "必须包含 {query} 和 {evidence}"
      }
    }
  },
  "config_direct_reply": {
    "description": "🎯 direct_reply 模式",
    "type": "object",
    "items": {
      "summary_provider_id": {
        "description": "LLM 模型",
        "type": "string",
        "default": "",
        "_special": "select_provider",
        "hint": "为空时默认使用当前会话的模型"
      },
      "summary_prompt_source": {
        "description": "总结提示词来源",
        "type": "string",
        "default": "file",
        "options": ["file", "config"]
      },
      "summary_prompt_template": {
        "description": "总结提示词模板",
        "type": "text",
        "default": "你是一个严谨的联网浏览助手。请基于下面的 Obscura 浏览器材料回答用户问题。\n\n要求：\n1. 优先使用浏览器材料，不要把没有依据的内容说成事实。\n2. 结论后用 [1]、[2] 这样的编号标注来源。\n3. 如果材料不足，请明确说明不足，并给出已找到的信息。\n4. 如果材料包含图片或设计线索，请区分“页面文字/DOM 元数据能确认的内容”和“无法直接确认的视觉细节”。\n5. 用用户提问的语言回答，保持简洁但覆盖关键事实。\n\n总结侧重点：{summary_focus}\n\n用户问题：\n{query}\n\n浏览器材料：\n{evidence}\n",
        "hint": "必须包含 {query} 和 {evidence}"
      },
      "summary_prompt_file": {
        "description": "总结提示词文件",
        "type": "string",
        "default": "prompts/summary.md"
      }
    }
  },
  "config_search": {
    "description": "🌐 浏览器操作和搜索",
    "type": "object",
    "items": {
      "summary_focus": {
        "description": "搜索结果总结侧重点",
        "type": "string",
        "default": "auto",
        "options": ["auto", "content", "visual_design", "site_overview"]
      },
      "search_engine": {
        "description": "搜索引擎",
        "type": "string",
        "default": "duckduckgo_html",
        "options": ["duckduckgo_html", "custom"]
      },
      "search_url_template": {
        "description": "搜索 URL 模板",
        "type": "string",
        "default": "https://html.duckduckgo.com/html/?q={query}"
      },
      "result_count": {
        "description": "搜索结果数",
        "type": "int",
        "default": 5,
        "hint": "使用浏览器打开网页和抓取内容需要耗费时间，且会消耗设备性能，但是 Obscura 很快很轻"
      },
      "fetch_top_pages": {
        "description": "抓取搜索结果正文的数量",
        "type": "int",
        "default": 3,
        "hint": "推荐设置为小于搜索结果数且大于 0. 此数值设置较大会导致明显更多的 Token 消耗。本配置设为 0 则只抓取搜索摘要而没有正文内容"
      },
      "timeout_seconds": {
        "description": "抓取超时秒数",
        "type": "int",
        "default": 20
      },
      "max_page_chars": {
        "description": "单页正文字符数",
        "type": "int",
        "default": 4000
      }
    }
  },
  "config_media": {
    "description": "🖼️ 网页媒体",
    "type": "object",
    "items": {
      "enable_media_extraction": {
        "description": "启用媒体提取",
        "type": "bool",
        "default": true
      },
      "media_extract_mode": {
        "description": "媒体提取模式",
        "type": "string",
        "default": "images",
        "options": ["images", "metadata_only"]
      },
      "max_images_per_page": {
        "description": "单个网页图片提取数",
        "type": "int",
        "default": 5
      },
      "image_caption_provider_id": {
        "description": "图片描述模型",
        "type": "string",
        "default": "",
        "_special": "select_provider",
        "hint": "为空时默认使用当前会话的模型"
      }
    }
  },
  "config_advanced": {
    "description": "🚀 高级",
    "type": "object",
    "items": {
      "obscura_path": {
        "description": "Obscura 可执行文件路径",
        "type": "string",
        "default": "",
        "hint": "为空时会优先使用插件目录下的 obscura 文件夹内的二进制文件（需命名为 obscura）, 如果不存在则会尝试在系统 PATH 中寻找"
      },
      "proxy": {
        "description": "Obscura 代理地址",
        "type": "string",
        "default": ""
      },
      "user_agent": {
        "description": "自定义浏览器 UA",
        "type": "string",
        "default": ""
      },
      "stealth": {
        "description": "启用 Obscura Stealth 模式",
        "type": "bool",
        "default": false,
        "hint": "启用 Obscura 的特征隐匿模式，可用于反指纹识别和追踪器阻断"
      },
      "allow_private_urls": {
        "description": "允许访问本地和内网资源",
        "type": "bool",
        "default": false,
        "hint": "⚠️ 高风险选项，默认关闭，阻止通过浏览器读取本机或内网资源"
      }
    }
  }
}
